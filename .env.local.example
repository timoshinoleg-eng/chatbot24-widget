# ============================================
# AI API Configuration
# ============================================

# OpenRouter (PRIMARY provider)
# Модель: qwen/qwen-2.5-14b-instruct
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Z.AI (FALLBACK provider)
# Модель: glm-4.7-flash
# Get key: https://z.ai/
ZAI_API_KEY=your_zai_api_key_here

# OpenAI (for embeddings)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-large

# ============================================
# Debug Configuration
# ============================================

# Enable debug mode (shows model info in responses)
DEBUG_AI=true
DEBUG_SHOW_MODEL=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable structured JSON logs
ENABLE_STRUCTURED_LOGS=true

# ============================================
# Site Configuration
# ============================================

NEXT_PUBLIC_SITE_URL=https://chatbot24-widget.vercel.app

# ============================================
# Bitrix24 Integration
# ============================================

# Webhook URL for Bitrix24
# Setup: Bitrix24 → Applications → Webhooks → Incoming webhook
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxxxxxxxxx/

# Manager ID for new leads
BITRIX24_MANAGER_ID=1

# ============================================
# Redis (Upstash) - for caching and sessions
# ============================================

UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ============================================
# Project Configuration
# ============================================

PROJECT_NAME=chatbot24.su
PROJECT_PRICE_START=49000

# ============================================
# Feature Flags
# ============================================

# Enable hybrid RAG search
ENABLE_HYBRID_RAG=true

# Enable AI lead scoring
ENABLE_AI_SCORING=true

# Enable automated tasks
ENABLE_AUTO_TASKS=true

# Enable trigger communications
ENABLE_TRIGGERS=true
